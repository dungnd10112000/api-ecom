# pyenv
.python-version

# pipenv
#   According to pypa/pipenv#1053, pipenv should write to /dev/null if virtualenv is not in project
#   so we shouldn't write path to .venv here, but standard practice is to do so.
#   https://stackoverflow.com/questions/48364805/pipenv-where-to-keep-virtualenv-in-a-docker-container
#   Pipfile.lock should be checked in, but virtualenv should be ignored.
.venv/
venv/
ENV/
env/

